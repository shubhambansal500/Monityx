# Copy this file to keystore.properties and fill in your values.
# NEVER commit keystore.properties to source control — it is in .gitignore.
#
# Generate your keystore with:
#   keytool -genkey -v -keystore monityx-release.jks \
#     -alias monityx -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=monityx-release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=monityx
keyPassword=YOUR_KEY_PASSWORD
